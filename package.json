  "description": "Auto-print Shopify shipping labels to a Brother AirPrint printer on macOS, with a Telegram re-print bot.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
