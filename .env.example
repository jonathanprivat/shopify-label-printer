# ─────────────────────────────────────────────────────────────
#  Copy this file to ".env" and fill in your values.
#  NEVER commit the real .env file. (.gitignore already excludes it.)
# ─────────────────────────────────────────────────────────────

# ── Shopify ──────────────────────────────────────────────────
# Your store domain, e.g. my-store.myshopify.com
SHOPIFY_SHOP=your-store.myshopify.com
# Admin API access token from your custom app (scope: read_orders)
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
# Admin API version (pin it; bump deliberately)
SHOPIFY_API_VERSION=2025-01
# Webhook signing secret. For an admin-created webhook this is shown
# next to the webhook; for a custom app it's the app's API secret key.
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret

# ── Telegram ─────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...your_token
# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Get yours by messaging @userinfobot
TELEGRAM_OWNER_IDS=123456789

# ── Printer (CUPS / AirPrint) ────────────────────────────────
# Brother QL-1110NWB at 192.168.1.150. The exact CUPS queue name —
# confirm with: npm run list-printers  (spaces become underscores)
PRINTER_QUEUE=Brother_QL_1110NWB
# Media size passed to lp. Your printer reports the 4x6 shipping label as
# 103 x 164 mm, so the default matches that exactly (no scaling).
# If you install the Brother driver and it exposes a named size, you can
# also use that name here. Check with: lpoptions -p <queue> -l
PRINTER_MEDIA=Custom.103x164mm
# Label dimensions used when rendering the PDF (must match the media, in mm).
LABEL_WIDTH_MM=103
LABEL_HEIGHT_MM=164

# ── Server ───────────────────────────────────────────────────
# Local port the webhook server listens on (Cloudflare Tunnel points here)
PORT=8088
# Path Shopify posts to (keep it unguessable-ish)
WEBHOOK_PATH=/webhooks/orders-create
# Public URL of your Cloudflare Tunnel, used by `npm run register-webhook`
PUBLIC_BASE_URL=https://labels.yourdomain.com

# ── Behaviour ────────────────────────────────────────────────
# Reconciliation poll interval in seconds (0 disables the safety-net poller)
POLL_INTERVAL_SECONDS=120
# Where to keep the dedupe DB and rendered PDFs (relative to project root)
DATA_DIR=./data
